{
  "name": "@hadron/hadrontool-ms-exchange",
  "version": "0.1.0",
  "description": "Hadron MS Exchange tool — owns the Microsoft Graph email provider relationship: OAuth tokens, mail operations, and webhook subscriptions, behind a provider-neutral HTTP surface.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:test-setup": "DATABASE_URL=postgresql://holger@localhost:5432/hadrontool_ms_exchange_test prisma db push --skip-generate"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^6.8.2",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "isomorphic-fetch": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.8.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
