# Port the HTTP server listens on.
PORT=8080

# Node environment. `development` relaxes the boot guards below.
NODE_ENV=development

# ── Inbound auth ─────────────────────────────────────────────────────────
# Shared bearer token: every /ops/*, /connections* request must send
#   Authorization: Bearer <MS_EXCHANGE_TOOL_TOKEN>
# hadron-server holds the same value as MS_EXCHANGE_TOOL_TOKEN.
# Required in production — the service refuses to start without it.
MS_EXCHANGE_TOOL_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────
# The tool's OWN database (never core's). Holds encrypted refresh tokens,
# subscription state, dedupe + idempotency records.
DATABASE_URL=postgresql://holger@localhost:5432/hadrontool_ms_exchange

# ── Secrets ──────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of refresh tokens at rest.
# Distinct from core's HADRON_ENCRYPTION_KEY by design. Required in production.
TOKEN_ENCRYPTION_KEY=

# HMAC key deriving the per-subscription clientState Graph echoes back on
# every notification. Required in production.
WEBHOOK_CLIENT_STATE_SECRET=

# ── Microsoft OAuth app (multi-tenant Azure AD) ──────────────────────────
# The tool owns the client secret; hadron-server only builds the user-facing
# authorize URL (client id is public). Without these, /connections and all
# mail operations return typed errors — the HTTP surface still boots.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Webhook ingress (public) ─────────────────────────────────────────────
# Public base URL Microsoft Graph can reach for change notifications; the
# notificationUrl is <WEBHOOK_BASE_URL>/webhooks/msgraph. Only this route is
# publicly exposed (Traefik); the operations plane stays internal.
WEBHOOK_BASE_URL=

# ── Event plane (tool → core) ────────────────────────────────────────────
# Where normalized email events are POSTed (hadron-server's internal ingress),
# and the bearer token that call carries. Unset ⇒ events are logged + dropped.
CORE_EVENTS_URL=
CORE_EVENTS_TOKEN=

# Max request body size accepted by the JSON parser.
MAX_BODY_SIZE=2mb
